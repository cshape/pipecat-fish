# Copy to .env.local and fill in your keys.

# --- STT provider ------------------------------------------------------------
# deepgram (Deepgram Flux, default) | assemblyai
STT_PROVIDER=deepgram

# Deepgram (STT — Flux) — https://deepgram.com/
DEEPGRAM_API_KEY=

# AssemblyAI (STT — only used when STT_PROVIDER=assemblyai) — https://www.assemblyai.com/
ASSEMBLYAI_API_KEY=

# --- TTS ---------------------------------------------------------------------
# Fish Audio — https://fish.audio/
FISH_API_KEY=

# --- LLM ---------------------------------------------------------------------
# OpenAI key — used only when LLM_BASE_URL is NOT set (direct-OpenAI fallback).
OPENAI_API_KEY=

# Point the LLM at any OpenAI-compatible endpoint (e.g. self-hosted Gemma via
# SGLang). When LLM_BASE_URL is set it takes priority over OpenAI. See llm.py.
# LLM_BASE_URL=https://<your-sglang-host>/v1
# LLM_MODEL=google/gemma-4-26B-A4B-it
# LLM_API_KEY=
# LLM_TEMPERATURE=0.6

# Direct-OpenAI model when LLM_BASE_URL is unset (default: gpt-4o).
# OPENAI_MODEL=gpt-4o

# --- Deepgram Flux turn detection (optional tuning) --------------------------
# DEEPGRAM_FLUX_MODEL=flux-general-en
# DEEPGRAM_EOT_THRESHOLD=0.7        # 0.5–0.9; lower = snappier, more false ends
# DEEPGRAM_EOT_TIMEOUT_MS=3000      # max silence (ms) before forcing end-of-turn

# --- AssemblyAI + smart-turn (optional; STT_PROVIDER=assemblyai) -------------
# SMART_TURN_STOP_SECS=0.6          # worst-case end-of-turn wait
# ASSEMBLYAI_MIN_TURN_SILENCE_MS=100

# --- Fish TTS tuning (optional) ---------------------------------------------
# FISH_VOICE_ID=0e24ff9936d34df4bddce26398cf1311   # Maren (American F)
# FISH_MODEL=s2.1-pro
# FISH_OUTPUT_FORMAT=pcm
# FISH_SAMPLE_RATE=24000
# FISH_LATENCY=low

# --- Optional: Daily WebRTC transport for local dev -------------------------
# DAILY_API_KEY=
